// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials provider
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts Account[]
  sessions Session[]
  registrations MasterclassRegistration[]
  instructedMasterclasses Masterclass[]
  offers    Offer[]
  requests  Request[]
  sentExchangeRequests     ExchangeRequest[] @relation("SentExchangeRequests")
  receivedExchangeRequests ExchangeRequest[] @relation("ReceivedExchangeRequests")
  chatSessionsAsP1         ChatSession[]     @relation("ChatParticipant1")
  chatSessionsAsP2         ChatSession[]     @relation("ChatParticipant2")
  chatMessages             ChatMessage[]
  ratingsGiven             Rating[]          @relation("Reviewer")
  ratingsReceived          Rating[]          @relation("Reviewee")
  
  // Add your custom user fields here
  bio           String?
  skills        String[]   @default([])
  interests     String[]   @default([]) // e.g. ["BACKEND", "DEVOPS", "AI_ML"]
  location      String?
  website       String?
  
  // Social links
  github        String?
  linkedin      String?
  twitter       String?
  gmail         String?
  creditBalance Int       @default(0)
  creditTransactions CreditTransaction[]
}

model Masterclass {
  id              String   @id @default(cuid())
  title           String
  description     String?  @db.Text
  instructorId    String
  instructor      User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  instructorName  String
  category        String
  level           MasterclassLevel @default(INTERMEDIATE)
  date            DateTime
  time            String
  duration        String
  meetLink        String   // Google Meet link
  maxStudents     Int?
  creditCost      Int      @default(0)
  avatar          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  registrations   MasterclassRegistration[]
}

model MasterclassRegistration {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  masterclassId   String
  masterclass     Masterclass @relation(fields: [masterclassId], references: [id], onDelete: Cascade)
  registeredAt    DateTime @default(now())
  emailSent       Boolean  @default(false)
  
  @@unique([userId, masterclassId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Skill Swap Models
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  SkillCategory
  createdAt DateTime @default(now())
  
  offers    Offer[]
  requests  Request[]
  senderExchangeRequests   ExchangeRequest[] @relation("SenderSkills")
  receiverExchangeRequests ExchangeRequest[] @relation("ReceiverSkills")
}

model Offer {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, skillId])
}

model Request {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, skillId])
}

model ExchangeRequest {
  id              String   @id @default(cuid())
  senderId        String
  sender          User     @relation("SentExchangeRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId      String
  receiver        User     @relation("ReceivedExchangeRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  senderSkillId   String
  senderSkill     Skill    @relation("SenderSkills", fields: [senderSkillId], references: [id], onDelete: Cascade)
  receiverSkillId String
  receiverSkill   Skill    @relation("ReceiverSkills", fields: [receiverSkillId], references: [id], onDelete: Cascade)
  status          ExchangeStatus @default(PENDING)
  message         String?
  creditAmount    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([senderId, receiverId, senderSkillId, receiverSkillId])
  @@index([receiverId, status])
  @@index([senderId, status])

  chatSession     ChatSession?
}

model ChatSession {
  id                String   @id @default(cuid())
  exchangeRequestId String   @unique
  exchangeRequest   ExchangeRequest @relation(fields: [exchangeRequestId], references: [id], onDelete: Cascade)
  participant1Id    String
  participant1      User     @relation("ChatParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2Id    String
  participant2      User     @relation("ChatParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  status            SessionStatus @default(accepted)
  sessionType       SessionType   @default(exchange)
  teacherCompleted  Boolean       @default(false)
  learnerCompleted  Boolean       @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  messages          ChatMessage[]

  @@index([participant1Id])
  @@index([participant2Id])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String      @db.Text
  createdAt DateTime    @default(now())

  @@index([sessionId, createdAt])
}

model Rating {
  id         String   @id @default(cuid())
  reviewerId String
  revieweeId String
  sessionId  String?
  rating     Int
  review     String?
  createdAt  DateTime @default(now())

  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, sessionId])
  @@index([revieweeId])
}

model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Int
  type         CreditTransactionType
  source       String?
  balanceAfter Int
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([source])
  @@unique([userId, source])
}

// Custom enums
enum UserRole {
  USER
  ADMIN
  INSTRUCTOR
}

enum MasterclassLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SkillCategory {
  DEVOPS
  CLOUD
  WEB_DEVELOPMENT
  MOBILE
  DATA_SCIENCE
  UI_UX
  BACKEND
  FRONTEND
  DATABASE
  AI_ML
  CYBERSECURITY
  BLOCKCHAIN
  GAME_DEVELOPMENT
  TESTING
  OTHER
}

enum CreditTransactionType {
  ONBOARDING
  TEACH_REWARD
  LEARN_SPEND
  REFUND
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum SessionStatus {
  pending
  accepted
  completed
}

enum SessionType {
  exchange
  paid
}
