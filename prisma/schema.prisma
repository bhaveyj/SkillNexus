// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials provider
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts Account[]
  sessions Session[]
  registrations MasterclassRegistration[]
  instructedMasterclasses Masterclass[]
  offers    Offer[]
  requests  Request[]
  sentExchangeRequests     ExchangeRequest[] @relation("SentExchangeRequests")
  receivedExchangeRequests ExchangeRequest[] @relation("ReceivedExchangeRequests")
  
  // Add your custom user fields here
  bio           String?
  skills        String[]
  location      String?
  website       String?
  
  // Social links
  github        String?
  linkedin      String?
  twitter       String?
  gmail         String?
}

model Masterclass {
  id              String   @id @default(cuid())
  title           String
  description     String?  @db.Text
  instructorId    String
  instructor      User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  instructorName  String
  category        String
  level           MasterclassLevel @default(INTERMEDIATE)
  date            DateTime
  time            String
  duration        String
  meetLink        String   // Google Meet link
  maxStudents     Int?
  avatar          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  registrations   MasterclassRegistration[]
}

model MasterclassRegistration {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  masterclassId   String
  masterclass     Masterclass @relation(fields: [masterclassId], references: [id], onDelete: Cascade)
  registeredAt    DateTime @default(now())
  emailSent       Boolean  @default(false)
  
  @@unique([userId, masterclassId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Skill Swap Models
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  SkillCategory
  createdAt DateTime @default(now())
  
  offers    Offer[]
  requests  Request[]
  senderExchangeRequests   ExchangeRequest[] @relation("SenderSkills")
  receiverExchangeRequests ExchangeRequest[] @relation("ReceiverSkills")
}

model Offer {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, skillId])
}

model Request {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, skillId])
}

model ExchangeRequest {
  id              String   @id @default(cuid())
  senderId        String
  sender          User     @relation("SentExchangeRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId      String
  receiver        User     @relation("ReceivedExchangeRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  senderSkillId   String
  senderSkill     Skill    @relation("SenderSkills", fields: [senderSkillId], references: [id], onDelete: Cascade)
  receiverSkillId String
  receiverSkill   Skill    @relation("ReceiverSkills", fields: [receiverSkillId], references: [id], onDelete: Cascade)
  status          ExchangeStatus @default(PENDING)
  message         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([senderId, receiverId, senderSkillId, receiverSkillId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

// Custom enums
enum UserRole {
  USER
  ADMIN
  INSTRUCTOR
}

enum MasterclassLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SkillCategory {
  DEVOPS
  CLOUD
  WEB_DEVELOPMENT
  MOBILE
  DATA_SCIENCE
  UI_UX
  BACKEND
  FRONTEND
  DATABASE
  AI_ML
  CYBERSECURITY
  BLOCKCHAIN
  GAME_DEVELOPMENT
  TESTING
  OTHER
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}
