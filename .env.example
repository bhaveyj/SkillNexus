# Database
DATABASE_URL="postgresql://username:password@localhost:5432/skillnexus?schema=public"

# NextAuth.js
NEXTAUTH_SECRET="your-nextauth-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional - Add your own keys)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

OPENAI_API_KEY=""

# Email Provider (For masterclass registration emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@skillnexus.com"

# Note: For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate an App Password at: https://myaccount.google.com/apppasswords
# 3. Use the App Password as SMTP_PASSWORD

# Upstash Redis (for caching & rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""